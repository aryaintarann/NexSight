# Supabase — gunakan PUBLISHABLE_KEY, bukan ANON_KEY
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJxxx
SUPABASE_SERVICE_ROLE_KEY=

# AI Layer — OpenRouter
OPENROUTER_API_KEY=sk-or-xxx

# Job Queue
REDIS_URL=redis://localhost:6379

# Email Alerts (Resend — https://resend.com)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=alerts@yourdomain.com

# App URL (used in email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# White-label branding (all optional — defaults to NexSight)
NEXT_PUBLIC_BRAND_NAME=NexSight
NEXT_PUBLIC_BRAND_TAGLINE=Intelligence Platform
NEXT_PUBLIC_BRAND_COLOR=#22d3ee
NEXT_PUBLIC_BRAND_LOGO_URL=
